    "@nestjs/typeorm": "^8.1.4",
    "@sprocketbot/common": "^0.2.18",
    "discord-api-types": "^0.25.2",
    "reflect-metadata": "^0.1.13",
    "rimraf": "^3.0.2",
    "rxjs": "^7.2.0",
    "typeorm": "^0.3.7"
  },
  "devDependencies": {
    "@nestjs/cli": "^8.2.8",
    "@types/node": "^16.11.13",
    "ts-node": "^10.2.1",
    "typescript": "^4.3.2"
  }
