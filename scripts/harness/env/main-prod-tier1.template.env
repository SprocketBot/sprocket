# Hosted Tier 1 template for main production.
# Fill in actor-specific values locally; do not commit secrets or tokens.

HARNESS_ENV_NAME=main-prod
HARNESS_API_URL=https://api.sprocket.mlesports.gg/graphql

# Preferred auth mode: mint short-lived user tokens from one admin refresh token.
HARNESS_ADMIN_REFRESH_TOKEN=
HARNESS_ORGANIZATION_ID=2
HARNESS_LOGIN_AS_USER_ID=
HARNESS_SECONDARY_USER_ID=

# Alternate auth modes:
# HARNESS_ADMIN_BEARER_TOKEN=
# HARNESS_REFRESH_URL=https://api.sprocket.mlesports.gg/refresh
# HARNESS_REFRESH_TOKEN=
# HARNESS_SECONDARY_REFRESH_TOKEN=
# HARNESS_BEARER_TOKEN=
# HARNESS_SECONDARY_BEARER_TOKEN=

# League read
# HARNESS_FIXTURE_ID=

# Scrim lifecycle
HARNESS_MUTATION_CONFIRM=YES
HARNESS_GAME_MODE_ID=1
HARNESS_LEAVE_AFTER=1
HARNESS_REQUIRE_CHECKIN=true

# Future four-actor scrim shape (design only; not implemented yet):
# HARNESS_SCRIM_ACTOR_USER_IDS=3001,3000,3002,3003
# HARNESS_SCRIM_ACTOR_BEARER_TOKENS=
# HARNESS_SCRIM_GROUP_ASSIGNMENTS=
# HARNESS_SCRIM_EXPECTED_MAX_PLAYERS=4

# Replay submission
# HARNESS_SUBMISSION_ID=
# HARNESS_REPLAY_FILE_PATHS=/absolute/path/to/game1.replay,/absolute/path/to/game2.replay
# HARNESS_USE_MOCK_COMPLETION=false
