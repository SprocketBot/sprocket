# Tier 0 harness profile for lane main-dev (environments/main-dev.json).
# Non-secret defaults only. Adjust URLs if maintainer DNS differs from foundation template.
#
# Secrets (if ever needed for deeper checks): use a local override file or CI secret mount;
# do not commit credentials.

HARNESS_ENV_NAME=main-dev
HARNESS_WEB_URL=https://dev.sprocket.mlesports.gg
HARNESS_API_URL=https://api.dev.sprocket.mlesports.gg/graphql
HARNESS_EXPECTED_WEB_STATUSES=200,302
HARNESS_EXPECTED_WEB_MARKER="Sign in with Discord"
HARNESS_EXPECTED_API_STATUSES=200,400,401,403,405
HARNESS_DEPENDENCY_URLS=web=https://dev.sprocket.mlesports.gg,api=https://api.dev.sprocket.mlesports.gg/graphql
HARNESS_EXPECTED_DEPENDENCY_STATUSES=200,302,400,405
