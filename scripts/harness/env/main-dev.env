# Default Tier 0 profile for the main-dev lane (hosted pre-prod).
# Confirm hostnames against the active Pulumi dev stack before relying on this file.
HARNESS_ENV_NAME=main-dev
HARNESS_WEB_URL=https://dev.app.sprocket.gg
HARNESS_API_URL=https://api.dev.app.sprocket.gg/graphql
HARNESS_EXPECTED_WEB_STATUSES=200,302
HARNESS_EXPECTED_WEB_MARKER="Sign in with Discord"
HARNESS_EXPECTED_API_STATUSES=200,400,401,403,405
HARNESS_DEPENDENCY_URLS=web=https://dev.app.sprocket.gg,api=https://api.dev.app.sprocket.gg/graphql
HARNESS_EXPECTED_DEPENDENCY_STATUSES=200,302,400,405
